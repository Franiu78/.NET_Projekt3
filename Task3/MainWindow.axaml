<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="Task3.MainWindow"
        Title="Task3 - przetwarzanie obrazów">
    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16" RowSpacing="12">
        <!-- Górny pasek z krótkim opisem. -->
        <Border Background="#1E1E1E" CornerRadius="10" Padding="16">
            <StackPanel Spacing="4">
                <TextBlock Text="Zadanie 3 - przetwarzanie obrazów" FontSize="22" FontWeight="Bold" />
                <TextBlock Text="Wczytaj obraz i uruchom cztery filtry: grayscale, negative, threshold i mirror." Opacity="0.8" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Główna część okna. -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
            <!-- Lewy panel pokazuje obraz oryginalny i przyciski do pracy na pliku. -->
            <Border Background="#262626" CornerRadius="10" Padding="12">
                <Grid RowDefinitions="Auto,*" RowSpacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Wczytaj obraz" Click="LoadImage_Click" />
                        <Button Content="Uruchom filtry" Click="RunFilters_Click" />
                        <TextBlock Text="Podgląd wejściowego obrazu" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Grid.Row="1" Background="#151515" CornerRadius="8" Padding="8" ClipToBounds="True">
                        <Image x:Name="PreviewImage"
                               Stretch="Uniform"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch" />
                    </Border>
                </Grid>
            </Border>

            <!-- Prawy panel zbiera wyniki filtrów i pokazuje je jako miniatury. -->
            <Border Grid.Column="1" Background="#262626" CornerRadius="10" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock Text="Filtry" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="Wyniki filtrów pojawią się poniżej po kliknięciu przycisku." Opacity="0.8" TextWrapping="Wrap" />

                    <UniformGrid Columns="2" Rows="2" Margin="0,4,0,0">
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="8" Margin="0,0,8,8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Grayscale" FontWeight="Bold" />
                                <Image x:Name="GrayscaleImage" Height="120" Stretch="Uniform" />
                            </StackPanel>
                        </Border>

                        <Border Background="#1A1A1A" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Negative" FontWeight="Bold" />
                                <Image x:Name="NegativeImage" Height="120" Stretch="Uniform" />
                            </StackPanel>
                        </Border>

                        <Border Background="#1A1A1A" CornerRadius="8" Padding="8" Margin="0,0,8,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Threshold" FontWeight="Bold" />
                                <Image x:Name="ThresholdImage" Height="120" Stretch="Uniform" />
                            </StackPanel>
                        </Border>

                        <Border Background="#1A1A1A" CornerRadius="8" Padding="8">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Mirror" FontWeight="Bold" />
                                <Image x:Name="MirrorImage" Height="120" Stretch="Uniform" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="10" Padding="12">
            <TextBlock x:Name="StatusText" Text="Gotowe do wczytania obrazu." />
        </Border>
    </Grid>
</Window>
